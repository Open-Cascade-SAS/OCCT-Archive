pload MODELING VISUALIZATION
vclear
vinit View1
vlight -clear

vbackground -color GRAY
vrenderparams -shadingModel PHONG
vlight -add ambient -COLOR WHITE -intensity 0.1

box b 10 10 10 30 30 30
vdisplay b -dispMode 1
vaspects b -material Brass
vfit

