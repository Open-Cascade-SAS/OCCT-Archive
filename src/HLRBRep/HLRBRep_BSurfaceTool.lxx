HLRBRep_BSurfaceTool::D2(const Handle(BRepAdaptor_Surface)& S,
			 const Standard_Real U,
			 const Standard_Real V,
			 gp_Pnt& P,
			 gp_Vec& D1U,
			 gp_Vec& D1V,
			 gp_Vec& D2U,
