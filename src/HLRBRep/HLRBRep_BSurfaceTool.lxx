{ S->D2(U,V,P,D1U,D1V,D2U,D2V,D2UV); }

//=======================================================================
//function : D3
//purpose  : 
//=======================================================================

inline void
HLRBRep_BSurfaceTool::D3(const Handle(BRepAdaptor_Surface)& S,
			 const Standard_Real U,
			 const Standard_Real V,
			 gp_Pnt& P,
			 gp_Vec& D1U,
			 gp_Vec& D1V, 
			 gp_Vec& D2U,
			 gp_Vec& D2V,
			 gp_Vec& D2UV,
			 gp_Vec& D3U,
			 gp_Vec& D3V,
			 gp_Vec& D3UUV,
			 gp_Vec& D3UVV)
{ S->D3(U,V,P,D1U,D1V,D2U,D2V,D2UV,D3U,D3V,D3UUV,D3UVV); }

